# Beispiel .env (lokal)

# Telegram Bot Token
ZEITFLOW_BOT_TOKEN=""

# SQLite DB-Datei im persistenten Volume
# Empfehlung: /data/zeitflow.db
ZEITFLOW_DB_PATH="/data/zeitflow.db"

# Optional: abweichende Pfade/Dateinamen für die Excel-Vorlagen
# Standard: SMF_2026_KW13.xlsx und Stundentabelle_Vadim.xlsx
# ZEITFLOW_TEMPLATE_KUNDE=""
# ZEITFLOW_TEMPLATE_INTERN=""
